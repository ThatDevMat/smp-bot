{
  "name": "smp-bot",
  "version": "1.0.0",
  "description": "Discord bot for managing a Minecraft SMP server with DiscordSRV, AdvancedBans, and RCON integrations",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "deploy": "node deploy-commands.js",
    "dev": "node --watch src/index.js",
