    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "morgan": "^1.11.0",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3",
    "rcon-client": "^4.2.4",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "undici": "6.27.0"
