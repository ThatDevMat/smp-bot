# --- Logging ---
LOG_LEVEL=        # debug in development, info in production

# --- Discord ---
BOT_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_main_guild_id_here

# --- RCON (Minecraft Server) ---
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password_here

# --- MySQL (AdvancedBans) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=advancedbans
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=advancedbans

# --- Express Webhook (DiscordSRV) ---
WEBHOOK_PORT=3000
WEBHOOK_SECRET=your_webhook_secret_here

# --- Discord Channel IDs ---
CHANNEL_MINECRAFT_CHAT=000000000000000000
CHANNEL_SERVER_LOG=000000000000000000
CHANNEL_SERVER_STATUS=000000000000000000
CHANNEL_EVENTS=000000000000000000
CHANNEL_POLLS=000000000000000000

# --- Staff Role IDs (comma-separated for multiple roles) ---
STAFF_ROLE_IDS=000000000000000000,000000000000000000

# --- Backup (SQLite) ---
BACKUP_DIR=./backups          # Directory to store backup files
BACKUP_CRON=0 3 * * *        # Cron schedule for automatic backups
BACKUP_RETAIN_DAILY=30       # Number of daily backups to keep
BACKUP_RETAIN_WEEKLY=4       # Number of weekly backups to keep
